# Tripzy Backend Configuration
PORT=5000

# MongoDB URI (leave empty to run in zero-setup offline Demo Mode)
# Example: MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/tripzy
MONGODB_URI=

# JWT Secret (for securing user sessions)
JWT_SECRET=tripzy_super_secret_jwt_key_12345

# Razorpay API Credentials (leave empty to run in simulated checkout Demo Mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=tripzy_webhook_secret_123
